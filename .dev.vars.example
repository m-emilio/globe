# Copy to .dev.vars for local wrangler dev (never commit .dev.vars)
# Obtain Stripe keys from https://dashboard.stripe.com/apikeys
# Webhook secret from https://dashboard.stripe.com/webhooks (or stripe listen)

TRANSIT_PUBLICAPI_V4=your_transit_public_api_v4_key_here

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: reuse an existing Price instead of creating Example Product
# STRIPE_PRICE_ID=price_...
